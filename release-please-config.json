{
	"$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
	"include-component-in-tag": true,
	"include-v-in-tag": true,
	"tag-separator": "@",
	"separate-pull-requests": true,
	"pull-request-title-pattern": "chore(release): release ${component} ${version}",
	"packages": {
		"packages/eslint-config": {
			"package-name": "@inclusive-design/eslint-config",
			"release-type": "node"
		},
		"packages/markdownlint-config": {
			"package-name": "@inclusive-design/markdownlint-config",
			"release-type": "node"
		},
		"packages/stylelint-config": {
			"package-name": "@inclusive-design/stylelint-config",
			"release-type": "node"
		}
	}
}
